{
  "manifest_version": 3,
  "name": "Paperless Clipper",
  "version": "1.0.1",
  "description": "One-tap save the current webpage to your Paperless-ngx server.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "nativeMessaging",
    "scripting"
  ],
  "host_permissions": [],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Save to Paperless",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "64": "icon-64.png"
    }
  },
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png",
    "128": "icon-128.png",
    "256": "icon-256.png",
    "512": "icon-512.png"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "commands": {
    "save-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Save the current page to Paperless"
    }
  },
  "browser_specific_settings": {
    "safari": {
      "strict_min_version": "16.0"
    }
  }
}
